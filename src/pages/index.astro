---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import HowItWorks from '../components/HowItWorks.astro';
import AudioPreview from '../components/AudioPreview.astro';
import PricingCards from '../components/PricingCards.astro';
---

<Layout>
  <!-- overflow removed to fix mobile bounce -->
  <main class="pt-12">
    <!-- ATEMPORAL Logo / Header -->
    <header class="max-w-7xl mx-auto px-6 py-6">
      <div class="font-serif text-2xl tracking-widest uppercase text-charcoal/90">
        Atemporal
      </div>
    </header>

    <Hero />
    <HowItWorks />
    <AudioPreview />
    <PricingCards />

    <!-- Minimal Footer -->
    <footer class="text-center py-12 text-charcoal/50 text-xs sm:text-sm px-4">
      <div class="mb-4">
        &copy; {new Date().getFullYear()} Atemporal. Preservando el legado familiar.
      </div>
      <div class="flex justify-center flex-wrap items-center gap-x-4 gap-y-2 text-charcoal/40 hover:[&>a]:text-charcoal/70 transition-colors">
        <a href="#terminos">Términos de Servicio</a>
        <span class="opacity-30 hidden sm:inline">|</span>
        <a href="#privacidad">Política de Privacidad</a>
        <span class="opacity-30 hidden sm:inline">|</span>
        <a href="https://wa.me/573208316285" target="_blank" rel="noopener noreferrer">Contacto</a>
      </div>
    </footer>
  </main>
</Layout>

